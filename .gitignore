local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local plr = Players.LocalPlayer
local camera = workspace.CurrentCamera

local Window = Rayfield:CreateWindow({
    Name = "Fortblox Hub",
    LoadingTitle = "Loading Fortblox...",
    LoadingSubtitle = "by Blackwatch",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "Fortblox",
        FileName = "Settings"
    },
})

local Fortblox = Window:CreateTab("Fortblox 🔥")

-- ==================== HITBOX EXPANDER (wie vorher - stabil) ====================
_G.HeadSize = 10

Fortblox:CreateToggle({
    Name = "Hitbox All (Extern)",
    CurrentValue = false,
    Callback = function(Value)
        if Value then
            loadstring(game:HttpGet("https://pastebin.com/raw/EWnEDbeR"))()
        end
    end
})

Fortblox:CreateSlider({
    Name = "Hitbox Größe (1 - 1000)",
    Range = {1, 1000},
    Increment = 1,
    CurrentValue = 10,
    Callback = function(Value)
        _G.HeadSize = Value
    end
})

-- ==================== ANDERE FEATURES ====================

Fortblox:CreateToggle({
    Name = "Anti Fall",
    CurrentValue = false,
    Callback = function(Value)
        if Value then
            local part = Instance.new("Part")
            part.Anchored = true
            part.Size = Vector3.new(8, 1, 9)
            part.Transparency = 0.6
            part.Color = Color3.fromRGB(255, 140, 0)
            part.Parent = workspace

            local conn = RunService.Heartbeat:Connect(function()
                local char = plr.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") or char.Humanoid.Health <= 0 then
                    conn:Disconnect()
                    part:Destroy()
                    return
                end
                local root = char.HumanoidRootPart
                part.CFrame = CFrame.new(root.Position.X, root.Position.Y - 3.4, root.Position.Z)
            end)
        end
    end
})

Fortblox:CreateToggle({
    Name = "Infinite Jump",
    CurrentValue = false,
    Callback = function(Value)
        if Value then
            UserInputService.JumpRequest:Connect(function()
                local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum:ChangeState("Jumping") end
            end)
        end
    end
})

Fortblox:CreateButton({Name = "Anti Spawn", Callback = function() loadstring(game:HttpGet('https://pastebin.com/raw/VwZEwsmu'))() end})
Fortblox:CreateButton({Name = "Anti Lag", Callback = function() loadstring(game:HttpGet('https://pastebin.com/raw/A5qCVHJt'))() end})
Fortblox:CreateButton({Name = "Speed Boost", Callback = function() loadstring(game:HttpGet("https://pastebin.com/raw/xxsjQVVy"))() end})
Fortblox:CreateButton({Name = "Jump Boost", Callback = function() loadstring(game:HttpGet("https://pastebin.com/raw/JfCDcYFs"))() end})
Fortblox:CreateButton({Name = "Fly Toggle", Callback = function() loadstring(game:HttpGet('https://pastebin.com/raw/YvKv4AuY'))() end})
Fortblox:CreateButton({Name = "Nameless Admin", Callback = function() loadstring(game:HttpGet("https://raw.githubusercontent.com/FilteringEnabled/NamelessAdmin/main/Source"))() end})

-- ==================== ESP TAB (korrigiert) ====================
local ESPTab = Window:CreateTab("ESP 👁️")

local espEnabled = false
local tracersEnabled = false
local espObjects = {}

local function createESP(character)
    if not character or espObjects[character] then return end

    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Filled = false
    box.Color = Color3.fromRGB(0, 255, 0)
    box.Transparency = 1

    local nameTag = Drawing.new("Text")
    nameTag.Size = 15
    nameTag.Center = true
    nameTag.Outline = true
    nameTag.Color = Color3.fromRGB(255, 255, 255)

    local tracer = Drawing.new("Line")
    tracer.Thickness = 2
    tracer.Color = Color3.fromRGB(255, 0, 0)
    tracer.Transparency = 0.8

    espObjects[character] = {box = box, name = nameTag, tracer = tracer}
end

local function updateESP()
    for character, drawings in pairs(espObjects) do
        if not character.Parent or not character:FindFirstChild("HumanoidRootPart") then
            drawings.box:Remove()
            drawings.name:Remove()
            drawings.tracer:Remove()
            espObjects[character] = nil
            return
        end

        local root = character.HumanoidRootPart
        local topPos = camera:WorldToViewportPoint(root.Position + Vector3.new(0, 2.5, 0))
        local bottomPos = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.0, 0))

        if topPos.Z > 0 then
            local height = topPos.Y - bottomPos.Y
            local width = height * 0.6

            drawings.box.Size = Vector2.new(width, height)
            drawings.box.Position = Vector2.new(topPos.X - width/2, topPos.Y)
            drawings.box.Visible = espEnabled

            drawings.name.Text = character.Name
            drawings.name.Position = Vector2.new(topPos.X, topPos.Y - 20)
            drawings.name.Visible = espEnabled

            if tracersEnabled then
                drawings.tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                drawings.tracer.To = Vector2.new(topPos.X, topPos.Y)
                drawings.tracer.Visible = true
            else
                drawings.tracer.Visible = false
            end
        else
            drawings.box.Visible = false
            drawings.name.Visible = false
            drawings.tracer.Visible = false
        end
    end
end

ESPTab:CreateToggle({Name = "ESP Boxes + Names", CurrentValue = false, Callback = function(v) espEnabled = v end})
ESPTab:CreateToggle({Name = "Tracers", CurrentValue = false, Callback = function(v) tracersEnabled = v end})

RunService.RenderStepped:Connect(updateESP)

-- Auto ESP
for _, p in ipairs(Players:GetPlayers()) do
    if p.Character then createESP(p.Character) end
    p.CharacterAdded:Connect(function(c) createESP(c) end)
end

Rayfield:Notify({
    Title = "Fortblox Hub",
    Content = "Hitbox wieder wie vorher + ESP korrigiert",
    Duration = 5
})
